{
  "name": "retail-ecommerce-workspace",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:backend": "npm --prefix backend run dev",
    "dev:spring": "cd backend/stacks/java-springboot && mvn spring-boot:run",
    "dev:frontend": "npm --prefix frontend run dev -- --host 127.0.0.1 --port 5173",
    "build": "npm --prefix frontend run build",
    "install:all": "npm --prefix backend install && npm --prefix frontend install"
  }
}
